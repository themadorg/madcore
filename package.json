{
  "name": "madcore",
  "version": "1.1.0",
  "description": "Delta Chat–compatible web SDK: multi-account messaging over chatmail WebSocket, PGP-first, IndexedDB persistence",
  "license": "LGPL-3.0-or-later",
  "type": "module",
  "author": "The Mad Org",
  "homepage": "https://github.com/themadorg/madcore",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/themadorg/madcore.git"
  },
  "bugs": {
    "url": "https://github.com/themadorg/madcore/issues"
  },
  "keywords": [
    "delta-chat",
    "chatmail",
    "messaging",
    "pgp",
    "e2ee",
    "websocket",
    "sdk",
    "webxdc"
  ],
  "main": "./dist/sdk.js",
  "types": "./dist/sdk.d.ts",
  "exports": {
    ".": {
      "types": "./sdk.ts",
      "import": "./sdk.ts",
      "default": "./dist/sdk.js"
    },
    "./store": {
      "types": "./store.ts",
      "import": "./store.ts",
      "default": "./dist/store.js"
    },
    "./types": {
      "types": "./types.ts",
      "import": "./types.ts",
      "default": "./dist/types.js"
    },
    "./jsonrpc": {
      "types": "./jsonrpc/index.ts",
      "import": "./jsonrpc/index.ts",
      "default": "./dist/jsonrpc/index.js"
    }
  },
  "files": [
    "dist",
    "sdk.ts",
    "store.ts",
    "types.ts",
    "account",
    "lib",
    "jsonrpc",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run typecheck && bun run build",
    "test": "make test",
    "test:ci": "make test-ci",
    "test:rpc": "bun test test/rpc/",
    "test:init": "make test-init",
    "test:init-ci": "make test-init-ci",
    "test:full": "bun run test/full.ts",
    "test:single": "bun run test/single.ts",
    "test:two-party": "bun run test/two-party.ts",
    "test:advanced": "bun run test/advanced.ts",
    "test:interactive": "bun run test/interactive.ts",
    "test:group": "bun run test/interactive-group.ts",
    "test:join-group": "bun run test/join-group.ts",
    "test:channel": "bun run test/interactive-channel.ts",
    "test:live": "bun run test/live-madmail.ts",
    "test:live-full": "bun run test/live/run.ts",
    "test:ci-smoke": "bun run test/ci/smoke.ts",
    "test:ci-e2e": "bun run test/ci/run.ts",
    "test:e2e:madmail": "bash scripts/ci/start-madmail.sh && SERVER_URL=https://127.0.0.1:8443 NODE_TLS_REJECT_UNAUTHORIZED=0 bun run test:ci-e2e; bash scripts/ci/stop-madmail.sh",
    "test:sj-docker-up": "bash test/live/madmail-docker-up.sh",
    "test:sj-docker": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test test/live/securejoin-docker.test.ts test/live/messaging-docker.test.ts",
    "test:sj-docker-all": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test test/live/securejoin-docker.test.ts test/live/messaging-docker.test.ts",
    "test:msg-docker": "NODE_TLS_REJECT_UNAUTHORIZED=0 bun test test/live/messaging-docker.test.ts"
  },
  "dependencies": {
    "openpgp": "^6.0.1",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "bun-types": "^1.3.14",
    "typescript": "^5.4.0"
  }
}
